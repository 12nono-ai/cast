---
interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  headings: Heading[];
}

const { headings } = Astro.props;
const items = headings.filter((heading) => heading.depth === 2 || heading.depth === 3);
---

{
  items.length > 0 && (
    <aside class="toc-shell shell">
      <div class="toc-sticky">
        <p class="toc-title">On this page</p>
        <nav class="toc-nav" aria-label="Table of contents">
          {items.map((heading) => (
            <a
              href={`#${heading.slug}`}
              class:list={["toc-link", heading.depth === 3 && "is-nested"]}
            >
              {heading.text}
            </a>
          ))}
        </nav>
      </div>
    </aside>
  )
}

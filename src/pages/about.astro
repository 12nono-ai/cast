---
import BaseLayout from "../layouts/BaseLayout.astro";
import { site } from "../data/site";
---

<BaseLayout title="About" description="About the author, focus areas, and what this blog is for.">
  <section class="page-head shell">
    <span class="eyebrow">About</span>
    <h1 style="font-size:clamp(2.4rem,6vw,4.5rem); margin-top:1rem;">Technical writing with an engineering bias.</h1>
    <p class="lead" style="margin-top:1rem; max-width:58ch;">
      This site is for documenting the reasoning behind real implementation choices:
      architecture, debugging, tradeoffs, and lessons from shipping.
    </p>
  </section>

  <section class="about-grid">
    <div class="content-shell shell">
      <h2 style="font-size:2rem;">What I write about</h2>
      <p class="lead" style="margin-top:1rem;">
        I focus on frontend engineering, AI-assisted workflows, developer tooling,
        and the habits that make software teams move faster without losing rigor.
      </p>
      <div class="stack-list" style="margin-top:1.5rem;">
        <div>
          <h3>Topics</h3>
          <p class="muted">React, Astro, TypeScript, AI product workflows, debugging, shipping habits.</p>
        </div>
        <div>
          <h3>Writing style</h3>
          <p class="muted">Short on hype, long on decision quality, examples, and practical tradeoffs.</p>
        </div>
      </div>
    </div>

    <div class="content-shell shell">
      <h2 style="font-size:2rem;">Elsewhere</h2>
      <div class="link-list" style="margin-top:1rem;">
        <a class="button" href={site.social.github} target="_blank" rel="noreferrer">GitHub</a>
        <a class="button" href={site.social.x} target="_blank" rel="noreferrer">X / Twitter</a>
      </div>
      <p class="muted" style="margin-top:1.25rem;">
        Replace the placeholder profile links in <code>src/data/site.ts</code> before publishing.
      </p>
    </div>
  </section>
</BaseLayout>
